# Copy to .env.voice-transcribe and replace with real secrets before deploy.
OPENAI_API_KEY=sk-...
SUPABASE_SERVICE_ROLE_KEY=sbp-...
# Use the https base URL for your Supabase project (e.g., https://abc.supabase.co)
SUPABASE_URL=https://<project-ref>.supabase.co

# Optional: curl invocation helpers (falls back to SUPABASE_URL if missing)
NEXT_PUBLIC_SUPABASE_URL=
USER_JWT=
