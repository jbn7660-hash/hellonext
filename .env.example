# ============================
# ArcUp/HelloNext Golf Coaching Platform
# Environment Variables Template
# Phase 6 Configuration
# ============================

# ============================
# v1.1 기본 설정 (Basic Configuration)
# ============================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn@sentry.io/your_project_id
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# External API Services
OPENAI_API_KEY=sk-your_openai_api_key_here
SMOKE_TOKEN=your_smoke_token_here
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Payment Gateway (Toss Payments)
TOSS_CLIENT_KEY=test_ck_live_your_toss_client_key
TOSS_SECRET_KEY=test_sk_live_your_toss_secret_key

# ============================
# v2.0 Patent Engine 설정 (Patent Engine Configuration)
# ============================

# Measurement Confidence (DC-2)
# T1: High confidence threshold for primary metrics
# T2: Low confidence threshold for secondary metrics
# K: Calibration constant for confidence weighting
CONFIDENCE_T1=0.7
CONFIDENCE_T2=0.4
CONFIDENCE_K=1.0

# Causal Graph Engine (F-015)
# Version identifier for causal inference model
CAUSAL_GRAPH_VERSION=v1.0
# Batch size for edge calibration operations
EDGE_CALIBRATION_BATCH_SIZE=10
# Interval in hours for periodic edge recalibration
EDGE_CALIBRATION_INTERVAL_HOURS=1

# Voice FSM (DC-5) - 음성 상태 머신 설정
# Timeout in seconds for FSM recovery mechanism
FSM_RECOVERY_TIMEOUT_SEC=30
# Maximum retry attempts for speech-to-text processing
STT_MAX_RETRY=3

# Verification Queue (F-016)
# Daily verification limit per professional coach
VERIFICATION_DAILY_LIMIT_PER_PRO=50

# ============================
# Vercel 배포 (Vercel Deployment)
# ============================

# Vercel Authentication Token
VERCEL_TOKEN=your_vercel_token_here
# Vercel Organization ID
VERCEL_ORG_ID=your_vercel_org_id
# Vercel Project ID
VERCEL_PROJECT_ID=your_vercel_project_id

# ============================
# Supabase 배포 (Supabase Deployment)
# ============================

# Supabase Management API Token
SUPABASE_ACCESS_TOKEN=sbp_your_access_token_here
# Supabase Project Reference ID
SUPABASE_PROJECT_REF=your_project_ref

# ============================
# 데이터베이스 (Database Configuration)
# ============================

# PostgreSQL Connection String (used in development/testing)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ============================
# 개발 환경 (Development Configuration)
# ============================

# Node Environment
NODE_ENV=development
# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1
# Enable debug logging
DEBUG=arcup:*
