# ============================================================
# HelloNext Staging Environment Variables
# ============================================================
# Copy this to .env.staging and fill in real values.
# NEVER commit .env.staging to git!
# ============================================================

# ── Supabase ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── External APIs ────────────────────────────
OPENAI_API_KEY=sk-...
SMOKE_TOKEN=your-staging-smoke-token
KAKAO_REST_API_KEY=
KAKAO_REDIRECT_URI=https://your-staging.vercel.app/auth/callback
CLOUDINARY_CLOUD_NAME=hellonext-staging
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Toss Payments (Test Mode) ────────────────
TOSS_PAYMENTS_SECRET_KEY=test_sk_...
TOSS_PAYMENTS_CLIENT_KEY=test_ck_...

# ── Patent Engine ────────────────────────────
CONFIDENCE_T1=0.7
CONFIDENCE_T2=0.4
CONFIDENCE_K=1.0
FSM_TIMEOUT_MS=300000
CAUSAL_MAX_DEPTH=5
CALIBRATION_WINDOW_DAYS=30
EDIT_DELTA_RETENTION_DAYS=90
SCALAR_PRIMARY_FIX_ENABLED=true

# ── Sentry ───────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Vercel ───────────────────────────────────
VERCEL_ENV=staging

# ── Mobile (Expo) ────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
